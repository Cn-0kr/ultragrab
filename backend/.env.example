# 绑定地址 / 端口（uvicorn 启动时读取，可由命令行覆盖）
HOST=127.0.0.1
PORT=8000

# 临时下载目录（相对 backend/ 或绝对路径皆可）
DOWNLOAD_DIR=.tmp_downloads

# 单次批量解析最多 URL 数
MAX_BATCH_URLS=10

# 同时进行的下载任务并发上限
MAX_CONCURRENT_DOWNLOADS=3

# 单任务超时（秒）
TASK_TIMEOUT=600

# 任务完成后文件保留时间（秒）
FILE_RETENTION=3600

# 是否允许 /api/redirect 返回的 302（默认 true）；false 时强制回退为代理
ALLOW_REDIRECT=true

# CORS 允许的前端地址，逗号分隔；留空则默认放行本地开发
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- AI（DeepSeek）----------
# 必填：AI 摘要 / 导图 / 问答。留空则 /api/transcript 仍可用，但 summarize/mindmap/chat 返回 503
DEEPSEEK_API_KEY=

# 可选：兼容自建代理或官方以外的网关
# DEEPSEEK_API_BASE=https://api.deepseek.com

# 可选：默认 deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat

# 可选：送入模型的字幕字符上限（下限约 8000）
# AI_MAX_TRANSCRIPT_CHARS=120000

# ---------- yt-dlp 字幕（尤其 B 站）----------
# 可选：Netscape 格式的 cookies.txt 绝对路径。
# 部分 B 站稿件在播放器 API 上标记 need_login_subtitle：匿名请求字幕列表为空，
# 网页登录能看到字幕时，需让 yt-dlp 携带已登录 Cookie 后再解析/拉字幕。
# YTDLP_COOKIE_FILE=C:/path/to/bilibili_cookies.txt

# ---------- Auth (JWT) ----------
# 必填：用于签发/校验 JWT。建议 ≥ 32 字节随机串：python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=
# 可选：access token 过期时间（秒），默认 7 天
# JWT_EXPIRES_SECONDS=604800

# ---------- Stripe（会员订阅）----------
# 必填：Stripe 测试 / 生产密钥，sk_test_... 或 sk_live_...（仅服务端，勿提交真实密钥）
STRIPE_SECRET_KEY=
# 本地用 Stripe CLI：`stripe listen --forward-to http://127.0.0.1:8000/api/stripe/webhook`
# 必须把 CLI 输出的 whsec_ 填在这里（每次新 listen 可能不同）。不要用 Dashboard「网页端点」的签名密钥替代 CLI 的 whsec。
# 若已修改本项仍返回 Webhook 400：检查 Windows/Anaconda 用户环境变量是否残留同名键；
# 本应用加载 backend/.env 时会覆盖已存在变量（override），改完后务必重启 uvicorn。
STRIPE_WEBHOOK_SECRET=
# 必填：Dashboard 中 CNY 月付 Price 的 price_...
STRIPE_PRICE_PRO_MONTHLY=
# 必填（生产）：前端访问域名（无尾斜杠），用于 success_url / cancel_url。
# 生产示例：https://ultragrab.0kr.xin
PUBLIC_FRONTEND_ORIGIN=http://127.0.0.1:5173

# 可选：SQLite 文件路径，默认 backend/billing.db
# BILLING_DB_PATH=./billing.db
