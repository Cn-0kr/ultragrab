# 绑定地址 / 端口（uvicorn 启动时读取，可由命令行覆盖）
HOST=127.0.0.1
PORT=8000

# 临时下载目录（相对 backend/ 或绝对路径皆可）
DOWNLOAD_DIR=.tmp_downloads

# 单次批量解析最多 URL 数
MAX_BATCH_URLS=10

# 同时进行的下载任务并发上限
MAX_CONCURRENT_DOWNLOADS=3

# 单任务超时（秒）
TASK_TIMEOUT=600

# 任务完成后文件保留时间（秒）
FILE_RETENTION=3600

# 是否允许 /api/redirect 返回的 302（默认 true）；false 时强制回退为代理
ALLOW_REDIRECT=true

# CORS 允许的前端地址，逗号分隔；留空则默认放行本地开发
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
